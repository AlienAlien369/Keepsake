# --- Database ---------------------------------------------------------
# Any Postgres connection string works: Neon, Vercel Postgres, Supabase,
# Railway, local Postgres, or the `db` service in docker-compose.yml.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- Sessions -----------------------------------------------------------
# A long random string used to sign login cookies.
SESSION_SECRET="session_farewell_key"

# --- Initial admin account (used by `npm run db:seed`) ------------------
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="admin_farewell_key"
ADMIN_NAME="Your Name"

# --- Email notifications (Resend) ----------------------------------------
# When an employee replies in their thread, an email is sent to
# groverlakshya.25.lg@gmail.com. Get a key at https://resend.com,
# and a "from" address on a domain you've verified there
# (Resend's onboarding@resend.dev works for quick testing).
RESEND_API_KEY="resend_farewell_key"
RESEND_FROM_EMAIL="Keepsake <onboarding@resend.dev>"

# --- Site URL -------------------------------------------------------------
# Used for metadata, OpenGraph images, and links inside notification emails.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
